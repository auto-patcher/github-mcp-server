{
  "annotations": {
    "destructiveHint": false,
    "openWorldHint": true,
    "title": "Add Issue Comment Reaction"
  },
  "description": "Add a reaction to a GitHub issue comment.",
  "inputSchema": {
    "properties": {
      "comment_id": {
        "description": "The ID of the issue comment to react to",
        "type": "number"
      },
      "content": {
        "description": "The reaction type",
        "enum": [
          "+1",
          "-1",
          "laugh",
          "confused",
          "heart",
          "hooray",
          "rocket",
          "eyes"
        ],
        "type": "string"
      },
      "owner": {
        "description": "Repository owner (username or organization)",
        "type": "string"
      },
      "repo": {
        "description": "Repository name",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "comment_id",
      "content"
    ],
    "type": "object"
  },
  "name": "add_issue_comment_reaction"
}