{
  "annotations": {
    "destructiveHint": false,
    "openWorldHint": true,
    "title": "Add Pull Request Review Comment Reaction"
  },
  "description": "Add a reaction to a pull request review comment.",
  "inputSchema": {
    "properties": {
      "comment_id": {
        "description": "The ID of the pull request review comment to react to",
        "type": "number"
      },
      "content": {
        "description": "The reaction type",
        "enum": [
          "+1",
          "-1",
          "laugh",
          "confused",
          "heart",
          "hooray",
          "rocket",
          "eyes"
        ],
        "type": "string"
      },
      "owner": {
        "description": "Repository owner (username or organization)",
        "type": "string"
      },
      "repo": {
        "description": "Repository name",
        "type": "string"
      }
    },
    "required": [
      "owner",
      "repo",
      "comment_id",
      "content"
    ],
    "type": "object"
  },
  "name": "add_pull_request_review_comment_reaction"
}